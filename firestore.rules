rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isOrganizer(resource) {
      return isAuth() && (
        resource.data.organizerId == request.auth.uid ||
        resource.data.createdBy == request.auth.uid
      );
    }

    // Perfiles de usuario
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isUser(userId);
    }

    // Ligas
    match /leagues/{leagueId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isOrganizer(resource);
    }

    // Torneos y subcolecciones
    match /tournaments/{tournamentId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isOrganizer(resource);

      match /registrations/{regId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update, delete: if isAuth() && (
          resource.data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.organizerId == request.auth.uid ||
          get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.createdBy == request.auth.uid
        );
      }

      match /groups/{groupId} {
        allow read: if isAuth();
        allow write: if isAuth() && (
          get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.organizerId == request.auth.uid ||
          get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.createdBy == request.auth.uid
        );
      }

      match /matches/{matchId} {
        allow read: if isAuth();
        allow write: if isAuth() && (
          get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.organizerId == request.auth.uid ||
          get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.createdBy == request.auth.uid
        );
      }
    }

    // Reservas y configuraciones de turnos
    match /turnoReservations/{reservationId} {
      allow read, write: if isAuth();
    }

    match /turnosConfigs/{configId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // Solicitudes de inscripción a ligas
    match /leagueRegistrationRequests/{requestId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        resource.data.organizerId == request.auth.uid
      );
    }

    // Conversaciones — solo participantes mayores de 14, o usuarios con rol organizador
    function chatHabilitadoParaUsuario() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.chatHabilitado == true;
    }

    function esOrganizador() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "organizer";
    }

    function puedeUsarChat() {
      return chatHabilitadoParaUsuario() || esOrganizador();
    }

    function esConversacionDelSistema(participants) {
      return "padelnexo-system" in participants;
    }

    match /conversations/{conversationId} {
      allow read: if isAuth() &&
        request.auth.uid in resource.data.participants &&
        (puedeUsarChat() || esConversacionDelSistema(resource.data.participants));
      allow write: if isAuth() &&
        puedeUsarChat() &&
        (request.auth.uid in resource.data.participants ||
         (esConversacionDelSistema(resource.data.participants) &&
          request.resource.data.lastMessageSenderId == "padelnexo-system"));
      allow create: if isAuth() && puedeUsarChat();

      match /messages/{messageId} {
        allow read: if isAuth() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants &&
          (puedeUsarChat() || esConversacionDelSistema(
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          ));
        allow create: if isAuth() && puedeUsarChat();
      }
    }

    // Invitaciones
    match /invitations/{invitationId} {
      allow read: if isAuth() && (
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId == request.auth.uid
      );
      allow create: if isAuth();
      allow update, delete: if isAuth() && (
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId == request.auth.uid
      );
    }

    // Favoritos de ligas
    match /leagueFavorites/{favoriteId} {
      allow read, write: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
    }

    // Solicitudes de complejo
    match /complexRequests/{requestId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // Solicitudes de organizador
    match /organizerRequests/{requestId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // Reportes
    match /reports/{reportId} {
      allow create: if isAuth();
      allow read, update, delete: if isAuth() && resource.data.reporterId == request.auth.uid;
    }

    // Bloqueos entre usuarios
    match /userBlocks/{blockId} {
      allow read, write: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
    }
  }
}
