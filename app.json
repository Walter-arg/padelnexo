{
  "expo": {
    "name": "PadelNexo",
    "slug": "padelnexo",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "scheme": "com.padelnexo.app",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/padelnexo-logo-full.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F6F8"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "updates": {
      "url": "https://u.expo.dev/70621faf-0db4-4145-b973-4803e2eb209d",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "android": {
      "package": "com.padelnexo.app",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "com.padelnexo.app",
              "host": "checkout",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4F6F8"
      }
    },
    "ios": {
      "supportsTablet": true
    },
    "extra": {
      "mercadoPago": {
        "turnosCheckoutUrl": "https://southamerica-east1-padelnexo-7e4d5.cloudfunctions.net/mercadoPagoCreateTurnoPreference",
        "turnosSyncUrl": "https://us-central1-padelnexo-7e4d5.cloudfunctions.net/mercadoPagoSyncTurnoPayment"
      },
      "eas": {
        "projectId": "70621faf-0db4-4145-b973-4803e2eb209d"
      }
    },
    "owner": "waltwr",
    "plugins": [
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "PadelNexo usa tu ubicacion para mostrarte complejos, turnos, ligas y jugadores cercanos."
        }
      ],
      "expo-asset"
    ]
  }
}
