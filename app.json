{
  "expo": {
    "name": "PadelNexo",
    "slug": "padelnexo",
    "version": "1.0.0",
    "scheme": "com.padelnexo.app",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/padelnexo-logo-full.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F6F8"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.padelnexo.app",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4F6F8"
      }
    },
    "ios": {
      "supportsTablet": true
    },
    "extra": {
      "eas": {
        "projectId": "70621faf-0db4-4145-b973-4803e2eb209d"
      }
    },
    "owner": "waltwr",
    "plugins": [
      "expo-web-browser"
    ]
  }
}
